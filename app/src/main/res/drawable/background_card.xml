<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Borde blanco grueso -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="#FFFFFF"/> <!-- Borde color blanco -->
            <corners android:radius="16dp"/> <!-- Bordes redondeados -->
        </shape>
    </item>

    <!-- Degradado interior -->
    <item android:inset="4dp"> <!-- Grosor del borde: 4dp -->
        <shape android:shape="rectangle">
            <gradient
                android:startColor="#FFFFFF"
                android:endColor="#E8D7A1"
                android:angle="45"/>
            <corners android:radius="12dp"/> <!-- Radio interior menor -->
        </shape>
    </item>
</layer-list>
