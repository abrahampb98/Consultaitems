<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/frmseleccionitem"
    android:orientation="vertical">

    <LinearLayout
        android:id="@+id/tabla"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="40dp"
        android:orientation="horizontal"
        android:baselineAligned="false"
        android:weightSum="10"
        android:showDividers="middle"
        android:divider="@drawable/divider_vertical"
        android:dividerPadding="2dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/txtTransaccionDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Transacción"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtBancoDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Banco"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtDocDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.8"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="center"
            android:text="# Doc."
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtCtaDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.35"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="# Cta."
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtFechaDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.15"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Fecha"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtValorDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:gravity="end"
            android:text="Valor"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtConceptoDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.45"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Concepto"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <TextView
            android:id="@+id/txtObservacionDE"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.8"
            android:paddingStart="4dp"
            android:paddingEnd="4dp"
            android:text="Observación"
            android:textSize="@dimen/font_size_Recibo"
            android:textColor="@color/black" />

        <ImageView
            android:id="@+id/eliminarDE"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="0.45"
            android:padding="4dp"
            android:scaleType="centerInside"
            android:src="@mipmap/ic_eliminar_round" />

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
