<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/frmseleccionitem"
    android:orientation="vertical"
    tools:ignore="MissingDefaultResource">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutItem2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="10"
            android:padding="0dp"
            android:gravity="center_vertical"
            tools:ignore="MissingConstraints">

            <TextView
                android:id="@+id/tvSecCR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.5"
                android:gravity="center"
                android:text="123"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvClienteNombreCR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:text="Nombre del Cliente"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvCiudadCR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ciudad"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvDiaCR"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.9"
                android:text="Día"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />


            <!-- Columna de la casilla (tiene el peso) -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:gravity="center"
            android:orientation="vertical">

            <CheckBox
                android:id="@+id/chkVisitaCR"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:buttonTint="?android:attr/colorPressedHighlight"
                android:text=""
                android:minWidth="0dp"
                android:minHeight="0dp"/>
        </LinearLayout>


            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:gravity="center"
                android:orientation="vertical">
                <CheckBox
                    android:id="@+id/chkCobroCR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?android:attr/colorPressedHighlight"
                    android:text=""
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:gravity="center"
                android:orientation="vertical">
                <CheckBox
                    android:id="@+id/chkVentaCR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?android:attr/colorPressedHighlight"
                    android:text=""
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="0.7"
                android:gravity="center"
                android:orientation="vertical">
                <CheckBox
                    android:id="@+id/chkGTCR"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:buttonTint="?android:attr/colorPressedHighlight"
                    android:text=""
                    android:minWidth="0dp"
                    android:minHeight="0dp"/>
            </LinearLayout>


            <TextView
                android:id="@+id/tvObservacionCR"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:gravity="center"
                android:text="Observación"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvEnvioCR"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="0.8"
                android:gravity="center"
                android:text="Envio"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />


        </LinearLayout>

        <LinearLayout
            app:layout_constraintTop_toBottomOf="@+id/layoutItem3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:ignore="UnknownIdInLayout">
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"/>
        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>