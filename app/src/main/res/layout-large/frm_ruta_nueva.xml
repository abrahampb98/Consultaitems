<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/frmseleccionitem"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutItem2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="5"
            android:padding="0dp"
            android:gravity="center_vertical"
            android:background="@color/white"
            tools:ignore="MissingConstraints">

            <TextView
                android:id="@+id/tvSecRN"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".5"
                android:gravity="center"
                android:text="123"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvClienteNombreRN"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2.4"
                android:text="Nombre del Cliente"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvCiudadRN"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Ciudad"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <TextView
                android:id="@+id/tvDiaRN"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".78"
                android:text="sabado"
                android:padding="5dp"
                android:textSize="@dimen/font_size_Ruta"
                android:textColor="@android:color/black" />

            <CheckBox
                android:id="@+id/chkVisitaRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:buttonTint="?android:attr/colorPressedHighlight" />

            <CheckBox
                android:id="@+id/chkCobroRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:buttonTint="?android:attr/colorPressedHighlight" />

            <CheckBox
                android:id="@+id/chkVentaRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:buttonTint="?android:attr/colorPressedHighlight" />

            <CheckBox
                android:id="@+id/chkGTRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:buttonTint="?android:attr/colorPressedHighlight" />

            <Button
                android:id="@+id/bntObservacionRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:gravity="center"
                android:background="@android:drawable/ic_input_add"
                android:text="" />


            <ImageView
                android:id="@+id/eliminarImageViewRN"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_gravity="center"
                android:layout_weight=".3"
                android:src="@mipmap/ic_eliminar_round" />
        </LinearLayout>


        <LinearLayout
            app:layout_constraintTop_toBottomOf="@+id/layoutItem3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            tools:ignore="UnknownIdInLayout">
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"/>
        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>