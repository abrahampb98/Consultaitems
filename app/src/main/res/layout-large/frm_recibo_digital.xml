<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/background"
    android:padding="10dp"
    tools:ignore="MissingDefaultResource">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintPrincipal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:ignore="MissingConstraints"
            tools:layout_editor_absoluteX="-42dp">

        <!-- **************************layout 1**********************************  -->
        <TextView
            android:id="@+id/textView4"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="Criterios"
            android:textColor="@color/black"
            android:textSize="20dp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
        </TextView>

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraint"
            style="@style/BorderedLayout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toBottomOf="@+id/textView4"
            android:background="@drawable/background"
            android:padding="10dp"
            tools:ignore="MissingConstraints">

            <LinearLayout
                android:id="@+id/linear"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight=".8"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_numero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Numero:"
                        android:gravity="center"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>


                    <EditText
                        android:id="@+id/txtNumeroRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:background="@drawable/edittext_background"
                        android:gravity="center"
                        android:hint="#"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnBuscarRD"
                        android:layout_width="0dp"
                        android:layout_weight=".8"
                        android:layout_height="wrap_content"
                        android:text="🔍"
                        android:textSize="18sp"
                        android:padding="4dp"
                        android:background="@drawable/button_background"
                        android:gravity="center" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight=".7"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_fecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Fecha:"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/txtFechaRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:hint="fecha"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:gravity="center"
                        android:paddingStart="8dp"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1.5"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_cliente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliente:"
                        android:gravity="center"
                        android:padding="8dp"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <AutoCompleteTextView
                        android:id="@+id/txtClienteRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="Ingrese el cliente"
                        android:completionThreshold="3"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:layout_weight="1"
                        android:paddingStart="8dp"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- Etiquetas con EditText después de cliente -->
            <LinearLayout
                android:id="@+id/linear2"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/linear"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight=".9"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_transaccion"
                        android:layout_width="120sp"
                        android:layout_height="match_parent"
                        android:text="Transacción:"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spTransaccion"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_banco"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Banco:"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spBanco"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:paddingStart="8dp"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_doc"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="# Doc:"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/txtDocRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="# CH. - #dep - # transf"
                        android:layout_weight="1"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:paddingStart="8dp"
                        android:inputType="number"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/linear3"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/linear2"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_cta"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="# Cta:"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/txtCtaRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:hint="Cuenta"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:focusable="false"
                        android:layout_weight="1"
                        android:paddingStart="8dp"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_fecha_transaccion"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Fecha:"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/txtFechaTransaccionRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:focusable="false"
                        android:hint="Seleccione fecha"
                        android:paddingStart="8dp"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_valor"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:text="Valor:"
                        android:padding="8dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <EditText
                        android:id="@+id/txtValorRD"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:hint="Ingrese el valor"
                        android:paddingStart="8dp"
                        android:inputType="numberDecimal"
                        android:background="@drawable/edittext_background"
                        android:paddingEnd="8dp"/>
                </LinearLayout>
            </LinearLayout>


            <LinearLayout
                android:id="@+id/linear5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/linear3"
                app:layout_constraintStart_toStartOf="parent">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight=".45"
                    android:orientation="vertical">


                    <TextView
                        android:id="@+id/tv_concepto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:padding="8dp"
                        android:text="Concepto:"
                        android:textColor="@color/black"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textStyle="bold" />

                    <Button
                        android:id="@+id/btnLimpiarRD"
                        android:layout_width="match_parent"
                        android:layout_height="40sp"
                        android:layout_marginLeft="30sp"
                        android:layout_marginRight="30sp"
                        android:background="@mipmap/ic_eliminar_round"></Button>
                </LinearLayout>



                <EditText
                    android:id="@+id/txtConceptoRD"
                    android:layout_width="0dp"
                    android:layout_weight="2.3"
                    android:layout_height="match_parent"
                    android:gravity="top|start"
                    android:hint="Concepto - # del Sri"
                    android:paddingStart="8dp"
                    android:textSize="@dimen/font_size_Recibo_Cab"
                    android:inputType="textMultiLine"
                    android:scrollHorizontally="false"
                    android:minLines="3"
                    android:maxLines="3"
                    app:layout_constraintStart_toEndOf="@id/tv_concepto"
                    app:layout_constraintTop_toTopOf="@id/tv_concepto"
                    android:background="@drawable/edittext_background"
                    app:layout_constraintWidth_percent="0.7" />


                <Button
                    android:id="@+id/btnCriteriosRD"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight=".24"
                    android:layout_marginTop="20dp"
                    android:text="🔍"
                    android:textSize="20sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintHorizontal_bias="1.0"
                    app:layout_constraintStart_toEndOf="@id/txtConceptoRD"
                    android:background="@drawable/button_background"
                    app:layout_constraintTop_toTopOf="@id/tv_concepto" />

            </LinearLayout>



            <LinearLayout
                android:id="@+id/linear6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:weightSum="3"
                android:layout_marginTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/linear5"
                app:layout_constraintStart_toStartOf="parent">

                <TextView
                    android:id="@+id/tv_observacion"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight=".54"
                    android:layout_marginTop="32dp"
                    android:layout_gravity=""
                    android:padding="8dp"
                    android:text="Observación:"
                    android:textSize="@dimen/font_size_Recibo_Cab"
                    android:textColor="@color/black"
                    android:textStyle="bold" />


                <EditText
                    android:id="@+id/txtObservacionRD"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2.2"
                    android:gravity="top|start"
                    android:textSize="@dimen/font_size_Recibo_Cab"
                    android:hint="Observacion - desgloce de facturas, abonos a retroventa, etc"
                    android:inputType="textMultiLine"
                    android:scrollHorizontally="false"
                    android:paddingStart="8dp"
                    android:minLines="3"
                    android:background="@drawable/edittext_background"
                    android:maxLines="3" />


                <Button
                    android:id="@+id/btnAgregarRD"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight=".2"
                    android:background="@android:drawable/ic_input_add"
                    android:layout_gravity="center"/>




            </LinearLayout>


        </androidx.constraintlayout.widget.ConstraintLayout>


            <TextView
                android:id="@+id/lblBusqueda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle"
                android:textColor="@color/black"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/constraint" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint2"
                style="@style/BorderedLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lblBusqueda"
                android:background="@drawable/background"
                android:padding="10dp"
                tools:ignore="MissingConstraints">



                <LinearLayout
                    android:id="@+id/tablaCabecera"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    android:baselineAligned="false"
                    android:weightSum="10"
                    android:showDividers="middle"
                    android:dividerPadding="2dp">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="Transc."
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="Banco"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="0.8"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="# Doc."
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.35"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="# Cta."
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.25"
                        android:paddingStart="4dp"
                        android:paddingEnd="4dp"
                        android:text="Fecha"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:paddingEnd="4dp"
                        android:text="Valor"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.45"
                        android:paddingEnd="4dp"
                        android:text="Concepto"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1.80"
                        android:paddingEnd="4dp"
                        android:text="Observación"
                        android:textSize="@dimen/font_size_Recibo_Cab"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <Space
                        android:layout_width="0dp"
                        android:layout_height="1dp"
                        android:layout_weight="0.45" />

                </LinearLayout>


            <LinearLayout
                android:id="@+id/linear4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                app:layout_constraintTop_toBottomOf="@id/tablaCabecera">

                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerRD"
                    android:layout_width="779sp"
                    android:layout_height="240sp"
                    android:layout_gravity="center_vertical"
                    android:layout_weight="1"
                    android:textSize="@dimen/font_size_Recibo_Cab" />
            </LinearLayout>



            <LinearLayout
                android:id="@+id/section_total"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:paddingTop="10dp"
                app:layout_constraintTop_toBottomOf="@id/linear4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textColor="@color/black"
                    android:textStyle="bold"
                    android:text="Total General:"
                    android:padding="8dp"/>

                <TextView
                    android:id="@+id/txtTotalGenRD"
                    android:layout_width="200dp"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:hint="0.00"
                    android:textColor="@color/black"
                    android:background="@drawable/edittext_background"
                    android:padding="8dp"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


        <TextView
            android:id="@+id/lblDetalle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:text="Soporte"
            android:textColor="@color/black"
            android:textSize="20dp"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@+id/constraint3"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="0.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/constraint2" />


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraint3"
            style="@style/BorderedLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/lblDetalle"
            tools:ignore="MissingConstraints"
            android:background="@drawable/background"
            android:padding="10dp"
            tools:layout_editor_absoluteY="671dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="@drawable/background"
                android:gravity="left">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="left">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:text="Archivo asociado:"
                    android:gravity="center"
                    android:padding="8dp"
                    android:textSize="@dimen/font_size_Recibo_Cab"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

                <Button
                    android:id="@+id/btnEnlaceRD"
                    android:layout_width="80dp"
                    android:textSize="@dimen/font_size_Recibo_Cab"
                    android:layout_height="match_parent"
                    android:background="@drawable/button_background"
                    android:text="No">
                </Button>

                <GridLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:columnCount="4"
                    android:rowCount="1"
                    android:paddingLeft="100dp"
                    android:orientation="horizontal"
                    android:layout_gravity="center">

                    <ImageView
                        android:id="@+id/imageViewPreview1"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@mipmap/ic_subir_imagen_round"
                        android:scaleType="fitXY"/> <!-- Placeholder image -->

                    <ImageView
                        android:id="@+id/imageViewPreview2"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@mipmap/ic_subir_imagen"
                        android:scaleType="fitXY"/> <!-- Placeholder image -->

                    <ImageView
                        android:id="@+id/imageViewPreview3"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@mipmap/ic_subir_imagen"
                        android:scaleType="fitXY"/> <!-- Placeholder image -->

                    <ImageView
                        android:id="@+id/imageViewPreview4"
                        android:layout_width="60dp"
                        android:layout_height="60dp"
                        android:src="@mipmap/ic_subir_imagen"
                        android:scaleType="fitXY"/> <!-- Placeholder image -->
                </GridLayout>

            </LinearLayout>


            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>


        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraint4"
            style="@style/BorderedLayout"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginTop="10dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintHorizontal_bias="1.0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/constraint3"
            tools:ignore="MissingConstraints"
            android:background="@drawable/background"
            tools:layout_editor_absoluteY="671dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnGuardarRD"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Guardar"
