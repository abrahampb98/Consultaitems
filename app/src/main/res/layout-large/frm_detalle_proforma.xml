<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:id="@+id/rootLayout"
    android:background="@drawable/frmseleccionitem"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    tools:ignore="MissingDefaultResource">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:weightSum="10">
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtNumPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="111"
                android:layout_weight="0.4"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:layout_gravity="center"
                android:id="@+id/txtReferenciaDetPF"
                android:paddingRight="5dp"
                android:layout_width="0dp"
                android:layout_height="17dp"
                android:text="Refere"
                android:layout_weight="2.2"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtDescItemPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="0.00"
                android:layout_weight="0.9"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtCantPF"
                android:paddingLeft="5dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="100"
                android:layout_weight="0.7"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtPrecPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="precio"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtsubPF"
                android:paddingLeft="5dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Preci"
                android:layout_weight="0.9"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtConDescPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="0.00"
                android:layout_weight="0.9"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtPesoPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="0.00"
                android:layout_weight="0.9"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtSubPesoPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="0.00"
                android:layout_weight="0.9"/>
            <TextView
                android:textSize="@dimen/font_size_small"
                android:gravity="center"
                android:id="@+id/txtLoteDPF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginRight="5dp"
                android:text="0.00"
                android:layout_weight="0.8"/>
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/eliminarImageViewPF"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:src="@mipmap/ic_eliminar_round"
                android:layout_weight="0.41"/>
        </LinearLayout>
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutItem">
            <View
                android:background="#cccccc"
                android:layout_width="match_parent"
                android:layout_height="1dp"/>
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>