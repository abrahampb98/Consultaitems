<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:ignore="MissingDefaultResource">

<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="8dp"
    tools:ignore="MissingDefaultResource">

    <!-- Spinner para seleccionar la semana -->
    <LinearLayout
        android:id="@+id/llSpinner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="0.5"
            android:gravity="center"
            android:text="Día:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <Spinner
            android:id="@+id/spinnerDias"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.4"
            android:background="@drawable/spinner_background"
            android:minWidth="48dp"
            android:minHeight="48dp"
            android:padding="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Fecha Inc.:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/txtFechaInicialRV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:background="@drawable/edittext_background"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:padding="10dp"
            android:text="01/01/2024" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:gravity="center"
            android:text="Fecha Fin:"
            android:textSize="18sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/txtFechaFinalRV"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1.2"
            android:background="@drawable/edittext_background"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:gravity="center"
            android:padding="10dp"
            android:text="01/01/2024" />

    </LinearLayout>



    <!-- **************************layout 1**********************************  -->
    <TextView
        android:id="@+id/lblPrinciapl"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Ruta Principal"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/llSpinner" />

    <LinearLayout
        android:id="@+id/labels"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:weightSum="6"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblPrinciapl"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"

        app:layout_constraintBottom_toTopOf="@id/recyclerViewR">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".4"
            android:gravity="center"
            android:text="#"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Nombre del Cliente"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".9"
            android:text="Ciudad"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".9"
            android:text="Monto"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".8"
            android:text="Cupo"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".7"
            android:text="Distancia"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Visita"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Cobro"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Venta"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="GT"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Obs."
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />
    </LinearLayout>


    <!-- RecyclerView para mostrar la lista de clientes -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewR"
        android:layout_width="0dp"
        android:layout_height="240dp"
        app:layout_constraintTop_toBottomOf="@id/labels"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/white"
        android:layout_marginBottom="8dp"
        android:scrollbars="vertical" />


    <TextView
        android:id="@+id/lblPendientes"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Pendientes"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recyclerViewR" />


    <LinearLayout
        android:id="@+id/labels2"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp"
        android:weightSum="6"
        android:padding="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblPendientes"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".4"
            android:gravity="center"
            android:text="#"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="Nombre del Cliente"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".9"
            android:text="Ciudad"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".96"
            android:text="Monto"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".8"
            android:text="Cupo"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".6"
            android:text="Día"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Visita"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Cobro"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Venta"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="GT"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Obs."
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewR2"
        android:layout_width="0dp"
        android:layout_height="190dp"
        app:layout_constraintTop_toBottomOf="@id/labels2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:background="@color/white"
        android:layout_marginBottom="8dp"
        android:scrollbars="vertical" />

    <TextView
        android:id="@+id/lblVisita"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Visitas No Programadas"
        android:textColor="@color/black"
        android:textSize="20dp"
        android:layout_marginTop="10dp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/recyclerViewR2" />


    <LinearLayout
        android:id="@+id/labels3"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="5"
        android:padding="8dp"
        android:gravity="center_vertical"
        app:layout_constraintTop_toBottomOf="@id/lblVisita"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".4"
            android:gravity="center"
            android:text="#"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2.1"
            android:text="Nombre del Cliente"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Ciudad"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight=".68"
            android:text="Día"
            android:textStyle="bold"
            android:padding="5dp"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Visita"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Cobro"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Venta"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="GT"
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />

        <TextView
            android:layout_width="40dp"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="Obs."
            android:textStyle="bold"
            android:textSize="@dimen/font_size_Ruta"
            android:textColor="@android:color/black" />
    </LinearLayout>
    <LinearLayout
        android:id="@+id/recyclerN"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        tools:ignore="MissingConstraints"
        app:layout_constraintTop_toBottomOf="@id/labels3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewR3"
            android:layout_width="0dp"
            android:layout_weight="1"
            android:layout_height="150dp"
            android:background="@color/white"
            android:scrollbars="vertical" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center">

            <ImageButton
                android:id="@+id/btnAgregarRN"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_input_add"
                android:contentDescription="Aumentar" />

        </LinearLayout>
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
</ScrollView>
