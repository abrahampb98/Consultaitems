<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="@drawable/background"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintPrincipal"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <TextView
                android:textSize="20dp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Criterios"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:orientation="horizontal"
                android:id="@+id/constraint"
                android:background="@drawable/background"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/textView4"
                style="@style/BorderedLayout">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layoutPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout
                        android:orientation="vertical"
                        android:id="@+id/layout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_marginRight="10dp"
                        android:layout_weight="1"
                        app:layout_constraintEnd_toStartOf="@+id/layout2"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent">
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:weightSum="2">
                            <TextView
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:layout_gravity="center"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginRight="13dp"
                                android:text="Item:"
                                android:layout_weight="0.3"/>
                            <AutoCompleteTextView
                                android:textSize="@dimen/font_size_medium"
                                android:gravity="center"
                                android:id="@+id/txtItemIC"
                                android:background="@drawable/edittext_background"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:hint="Ingrese el item"
                                android:completionThreshold="2"
                                android:layout_weight="1.7"
                                android:inputType="textNoSuggestions"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:weightSum="2">
                            <TextView
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:layout_gravity="center"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginRight="13dp"
                                android:text="Marca: "
                                android:layout_weight="0.3"/>
                            <AutoCompleteTextView
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:id="@+id/txtMarcaIC"
                                android:background="@drawable/edittext_background"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:hint="Ingrese la marca"
                                android:completionThreshold="2"
                                android:layout_weight="1.7"
                                android:inputType="textNoSuggestions"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:weightSum="2">
                            <TextView
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:layout_gravity="center"
                                android:layout_width="0dp"
                                android:layout_height="47dp"
                                android:layout_marginRight="18dp"
                                android:text="Cliente:"
                                android:layout_weight="0.3"/>
                            <AutoCompleteTextView
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:id="@+id/txtClienteIC"
                                android:background="@drawable/edittext_background"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:hint="Ingrese el cliente"
                                android:completionThreshold="3"
                                android:layout_weight="1.7"
                                android:inputType="textNoSuggestions"/>
                            <ImageButton
                                android:id="@+id/btnClienteIC"
                                android:background="@drawable/button_background"
                                android:visibility="invisible"
                                android:layout_width="60dp"
                                android:layout_height="40dp"
                                android:src="@drawable/ic_busqueda"
                                android:scaleType="fitCenter"/>
                        </LinearLayout>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:layout_marginTop="5dp"
                            android:weightSum="5">
                            <TextView
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:gravity="center_vertical"
                                android:layout_gravity="center"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:text="Fecha Inicial"
                                android:layout_weight="0.9"/>
                            <EditText
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:id="@+id/txtFechaInicialIC"
                                android:background="@drawable/edittext_background"
                                android:focusable="false"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:hint="fecha"
                                android:layout_weight="1.1"/>
                            <TextView
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold"
                                android:textColor="@color/black"
                                android:gravity="center_vertical"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:text="Fecha Final"
                                android:layout_weight="0.8"/>
                            <EditText
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:id="@+id/txtFechaFinalIC"
                                android:background="@drawable/edittext_background"
                                android:focusable="false"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:hint="fecha"
                                android:layout_weight="1.2"/>
                            <Button
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:id="@+id/btnBusquedaIC"
                                android:background="@drawable/button_background"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_marginLeft="10dp"
                                android:text="Buscar"
                                android:layout_weight="1"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
            <TextView
                android:textSize="20dp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:id="@+id/lblBusqueda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Detalles"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/constraint"/>
            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint2"
                android:background="@drawable/background"
                android:padding="5dp"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lblBusqueda"
                style="@style/BorderedLayout">
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/layout3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:weightSum="7">
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="# Sri"
                        android:layout_weight="1.3"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Bodega"
                        android:layout_weight="0.9"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Fecha Factura"
                        android:layout_weight="1.2"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Tipo Factura"
                        android:layout_weight="1.1"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Cantidad"
                        android:layout_weight="0.9"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Precio Venta"
                        android:layout_weight="1"/>
                    <TextView
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:textColor="@color/black"
                        android:gravity="center"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:text="Total"
                        android:layout_weight="0.6"/>
                </LinearLayout>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewIC"
                    android:background="@drawable/background"
                    android:layout_width="match_parent"
                    android:layout_height="580dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/layout3"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>