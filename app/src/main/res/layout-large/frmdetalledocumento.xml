<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/frmseleccionitem"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutItem2"
            app:layout_constraintTop_toTopOf="parent"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:orientation="horizontal"
            android:weightSum="8">


            <TextView
                android:id="@+id/txtBodegaDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight=".7"
                android:text="Precio Venta"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtInternoDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:text="Total"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtSriDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:text="Sri"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtFechaDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:text="Fecha"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtGuiarDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:text="Guia R"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtGuiatDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1.2"
                android:text="Guia T"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />

            <TextView
                android:id="@+id/txtTotalDC"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight=".8 "
                android:text="Total"
                android:gravity="center"
                android:textSize="@dimen/font_size_PreciosStock"
                android:textColor="@color/black" />






            <ImageView
                android:id="@+id/WebImageViewDF"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight=".3"
                android:layout_gravity="center"
                android:background="@android:color/darker_gray"
                android:src="?attr/actionModePasteDrawable" />

            <!-- Agregar espacio entre los ImageView -->
            <View
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight=".1" />

            <ImageView
                android:id="@+id/WebImageViewDC"
                android:layout_width="0dp"
                android:layout_height="20dp"
                android:layout_weight=".3"
                android:layout_gravity="center"
                android:background="@android:color/darker_gray"
                android:src="@android:drawable/stat_sys_download" />


        </LinearLayout>


        <LinearLayout
            app:layout_constraintTop_toBottomOf="@+id/layoutItem2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_width="wrap_content"
            android:layout_height="match_parent">
            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="#CCCCCC"/>
        </LinearLayout>


    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
