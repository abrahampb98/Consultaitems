<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:background="@drawable/background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutItem"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:weightSum="4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Factura : "
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:id="@+id/txtFacturaF"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="1234"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Sri:"
                android:layout_weight="0.4"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:id="@+id/txtSriF"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Nombre Cliente"
                android:layout_weight="1.6"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutItem2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:weightSum="4"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutItem">
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:text="Descuento : "
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:id="@+id/txtDescuentoF"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="1234"
                android:layout_weight="1"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Lote:"
                android:layout_weight="0.4"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:id="@+id/txtLoteF"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Nombre Cliente"
                android:layout_weight="1.6"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutItem3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutItem2">
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Observacion: "
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutItem4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutItem3">
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:id="@+id/txtObservacionF"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginLeft="7dp"
                android:text="$0.00"
                android:layout_weight="1"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:id="@+id/layoutHeaders"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:weightSum="6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutItem4">
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="left"
                android:paddingLeft="7dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Código"
                android:layout_weight="1.1"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="left"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Referencia"
                android:layout_weight="1.9"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Desct."
                android:layout_weight="0.7"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Cant."
                android:layout_weight="0.7"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Precio"
                android:layout_weight="0.7"/>
            <TextView
                android:textSize="@dimen/font_size_Facturas"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:gravity="center"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="Subt."
                android:layout_weight="0.9"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerViewDF"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginTop="4dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/layoutHeaders"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
