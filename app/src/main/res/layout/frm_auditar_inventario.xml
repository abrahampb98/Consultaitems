<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/background"
    android:padding="12dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/topCard"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:cardCornerRadius="14dp"
        app:cardElevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:id="@+id/tvBodega"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Bodega"
                    android:layout_marginEnd="10dp"/>
                <Spinner
                    android:id="@+id/spBodega"
                    android:background="@drawable/edittext_background"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:layout_marginLeft="20dp"
                    android:layout_weight="1"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>
            <View
                android:layout_width="match_parent"
                android:layout_height="10dp"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black"
                    android:id="@+id/tvReferencia"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Referecnia."
                    android:layout_marginEnd="5dp"/>
                <AutoCompleteTextView
                    android:textSize="@dimen/font_size_medium"
                    android:gravity="center_vertical"
                    android:id="@+id/editTextReferencia"
                    android:background="@drawable/edittext_background"
                    android:layout_width="0dp"
                    android:layout_height="44dp"
                    android:hint="Ingrese referencia"
                    android:completionThreshold="3"
                    android:layout_weight="1"
                    android:inputType="textNoSuggestions"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <FrameLayout
        android:id="@+id/cameraContainer"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        android:layout_marginBottom="12dp"
        app:layout_constraintBottom_toTopOf="@+id/btnEscanearQR"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/topCard">
        <androidx.camera.view.PreviewView
            android:id="@+id/camera_preview"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <View
            android:layout_gravity="center"
            android:id="@+id/qr_frame"
            android:background="@drawable/qr_frame_border"
            android:layout_width="240dp"
            android:layout_height="240dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@android:color/white"
            android:layout_gravity="bottom|center_horizontal"
            android:id="@+id/tvHint"
            android:background="#66000000"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="Alinea el código dentro del recuadro"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"/>
    </FrameLayout>
    <Button
        android:textColor="@color/black"
        android:id="@+id/btnEscanearQR"
        android:background="@drawable/button_background"
        android:layout_width="0dp"
        android:layout_height="44dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="12dp"
        android:text="Escanear"
        android:textAllCaps="false"
        android:paddingStart="18dp"
        android:paddingEnd="18dp"
        app:backgroundTint="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <FrameLayout
        android:id="@+id/detail_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:translationZ="30dp"
        android:elevation="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>