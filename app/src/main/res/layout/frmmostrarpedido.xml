<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:background="@drawable/background"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraint"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/layoutItem"
                android:layout_width="375dp"
                android:layout_height="match_parent"
                android:weightSum="2">
                <TextView
                    android:textSize="@dimen/font_size_cardView"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Cliente"
                    android:layout_weight="0.4"/>
                <EditText
                    android:textSize="@dimen/font_size_cardView"
                    android:id="@+id/txtBuscCliente"
                    android:background="@drawable/edittext_background"
                    android:paddingLeft="5dp"
                    android:layout_width="0dp"
                    android:layout_height="30sp"
                    android:hint="Ingrese nombre del cliente"
                    android:layout_weight="1.6"
                    android:inputType="textPersonName"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/layoutItem2"
                android:paddingTop="10dp"
                android:paddingBottom="6dp"
                android:layout_width="375dp"
                android:layout_height="match_parent"
                android:weightSum="4"
                app:layout_constraintTop_toBottomOf="@+id/layoutItem">
                <TextView
                    android:textSize="@dimen/font_size_cardView"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Fecha Inicial"
                    android:layout_weight="0.8"/>
                <EditText
                    android:textSize="@dimen/font_size_cardView"
                    android:gravity="center"
                    android:id="@+id/txtFechaInicial"
                    android:background="@drawable/edittext_background"
                    android:focusable="false"
                    android:layout_width="0dp"
                    android:layout_height="30sp"
                    android:hint="fecha"
                    android:layout_weight="1.1"/>
                <TextView
                    android:textSize="@dimen/font_size_cardView"
                    android:textStyle="bold"
                    android:gravity="center_vertical"
                    android:paddingLeft="5dp"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="Fecha Final"
                    android:layout_weight="0.8"/>
                <EditText
                    android:textSize="@dimen/font_size_cardView"
                    android:gravity="center"
                    android:id="@+id/txtFechaFinal"
                    android:background="@drawable/edittext_background"
                    android:focusable="false"
                    android:layout_width="0dp"
                    android:layout_height="30sp"
                    android:hint="fecha"
                    android:layout_weight="1.3"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/layoutItem3"
                android:layout_width="375dp"
                android:layout_height="match_parent"
                android:weightSum="1"
                app:layout_constraintTop_toBottomOf="@+id/layoutItem2">
                <Button
                    android:textSize="@dimen/font_size_medium"
                    android:id="@+id/btnBuscaXCliente"
                    android:background="@drawable/button_background"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="Buscar"
                    android:layout_weight="1"/>
            </LinearLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvPedidos"
                android:layout_width="375dp"
                android:layout_height="0dp"
                app:layout_constraintTop_toBottomOf="@+id/layoutItem3"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>
