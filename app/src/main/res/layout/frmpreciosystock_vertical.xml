<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background"
    android:padding="12dp"
    tools:ignore="MissingDefaultResource">

    <LinearLayout
        android:id="@+id/panelBusqueda"
        style="@style/BorderedLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@drawable/background"
        android:orientation="vertical"
        android:padding="12dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/textView4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Criterios de búsqueda"
            android:textColor="@color/black"
            android:textSize="20sp"
            android:textStyle="bold" />

        <!-- Primera línea: Referencia y Marca -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="8dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/txtRefView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:gravity="center_vertical"
                android:hint="Referencia"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

            <EditText
                android:id="@+id/txtMarcaView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:gravity="center_vertical"
                android:hint="Marca"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

        </LinearLayout>

        <!-- Segunda línea: Tipo producto y Familia -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="44dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/txtProductView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:gravity="center_vertical"
                android:hint="Tipo producto"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

            <EditText
                android:id="@+id/txtFamiliaView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:gravity="center_vertical"
                android:hint="Familia"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

        </LinearLayout>

        <!-- Tercera línea: Descripción y Buscar -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="4">

            <EditText
                android:id="@+id/txtDescrpView"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="6dp"
                android:layout_weight="3"
                android:background="@drawable/edittext_background"
                android:gravity="center_vertical"
                android:hint="Descripción"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

            <Button
                android:id="@+id/btnBusquedaPS"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@drawable/button_background"
                android:text="Buscar"
                android:textSize="@dimen/font_size_PreciosStock" />

        </LinearLayout>

    </LinearLayout>

    <LinearLayout
        android:id="@+id/panelSeleccion"
        style="@style/BorderedLayout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:background="@drawable/background"
        android:orientation="vertical"
        android:padding="10dp"
        app:layout_constraintTop_toBottomOf="@id/panelBusqueda"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Producto seleccionado"
            android:textColor="@color/black"
            android:textSize="16sp"
            android:textStyle="bold" />

        <!-- Primera línea: Marca y Tipo producto -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:layout_marginTop="6dp"
            android:orientation="horizontal"
            android:weightSum="2">

            <EditText
                android:id="@+id/txtMarcaSelect"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginEnd="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:focusable="false"
                android:hint="Marca"
                android:inputType="none"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

            <EditText
                android:id="@+id/txtProductSelect"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_marginStart="5dp"
                android:layout_weight="1"
                android:background="@drawable/edittext_background"
                android:focusable="false"
                android:hint="Tipo producto"
                android:inputType="none"
                android:paddingStart="10dp"
                android:paddingEnd="10dp"
                android:textSize="@dimen/font_size_PreciosStock" />

        </LinearLayout>

        <!-- Segunda línea: Descripción sola -->
        <EditText
            android:id="@+id/txtDescripcionSelect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="44dp"
            android:layout_marginTop="5dp"
            android:background="@drawable/edittext_background"
            android:focusable="false"
            android:hint="Descripción"
            android:inputType="none"
            android:maxLines="3"
            android:padding="10dp"
            android:textIsSelectable="true"
            android:textSize="@dimen/font_size_PreciosStock" />

    </LinearLayout>

    <TextView
        android:id="@+id/lblBusqueda"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="Resultados"
        android:textColor="@color/black"
        android:textSize="18sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/panelSeleccion"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerViewPS"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="6dp"
        android:background="@drawable/background"
        android:clipToPadding="false"
        android:paddingBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/lblBusqueda"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>