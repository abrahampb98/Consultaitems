<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/background"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/font_size_large"
        android:textStyle="bold"
        android:textColor="#0e0e0e"
        android:id="@+id/label_consulta_item"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp"
        android:text="Consulta de Criterios"/>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="8dp"
        android:weightSum="3">
        <TextView
            android:textSize="@dimen/font_size_large"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:id="@+id/label_descripcion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Criterio"
            android:layout_weight="0.7"
            android:layout_marginEnd="8dp"/>
        <Spinner
            android:id="@+id/spnCriteriosF"
            android:background="@drawable/spinner_background"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="2"/>
        <Button
            android:layout_gravity="center"
            android:id="@+id/bntAgregarF"
            android:background="@android:drawable/ic_input_add"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/font_size_large"
        android:textStyle="bold"
        android:textColor="#101010"
        android:id="@+id/label_resultados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp"
        android:text="Detalles"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/layoutItem3"
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:layout_marginTop="10dp"
        android:weightSum="6">
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="center_vertical"
            android:id="@+id/checkBoxSeleccion"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.3"/>
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/txtBodegaDT"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Bodega"
            android:layout_weight="1"/>
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/txtCodigoDT"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Numero Sri"
            android:layout_weight="1.7"/>
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/txtFechaDT"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Fecha Factura"
            android:layout_weight="1.2"/>
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/txtValorDT"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Valor"
            android:layout_weight="0.9"/>
        <TextView
            android:textSize="@dimen/font_size_medium"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:gravity="left"
            android:id="@+id/txtSaldoDT"
            android:paddingRight="10dp"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:text="Saldo"
            android:layout_weight="0.9"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:textSize="@dimen/font_size_large"
        android:id="@+id/recyclerviewItems"
        android:background="@drawable/background"
        android:layout_width="match_parent"
        android:layout_height="200dp"/>
</LinearLayout>
