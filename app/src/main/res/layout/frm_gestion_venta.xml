<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/background"
    android:padding="16dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <TextView
            android:textSize="@dimen/font_size_large"
            android:textStyle="bold"
            android:textColor="@color/black"
            android:id="@+id/label_descripcion"
            android:layout_width="95dp"
            android:layout_height="wrap_content"
            android:text="Reporte"
            android:layout_marginEnd="8dp"/>
        <Spinner
            android:id="@+id/spnCriteriosGV"
            android:background="@drawable/spinner_background"
            android:layout_width="0dp"
            android:layout_height="46dp"
            android:layout_weight="1"
            android:layout_marginEnd="10dp"/>
        <Button
            android:id="@+id/bntBuscarGV"
            android:background="@drawable/ic_busqueda"
            android:layout_width="46dp"
            android:layout_height="46dp"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">
        <TextView
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Fecha Inicial:"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:gravity="center"
            android:id="@+id/txtFechaIncGV"
            android:background="@drawable/edittext_background"
            android:focusable="false"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="13/01/2026"
            android:layout_weight="1"
            android:layout_marginEnd="8dp"/>
        <TextView
            android:textStyle="bold"
            android:textColor="@color/black"
            android:layout_width="100dp"
            android:layout_height="wrap_content"
            android:text="Fecha Final:"
            android:layout_marginEnd="4dp"/>
        <TextView
            android:gravity="center"
            android:id="@+id/txtFechaFinGV"
            android:background="@drawable/edittext_background"
            android:focusable="false"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:text="13/01/2026"
            android:layout_weight="1"/>
    </LinearLayout>
    <TextView
        android:textSize="14dp"
        android:textStyle="bold"
        android:textColor="#101010"
        android:id="@+id/label_resultados"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="4dp"
        android:text="Detalles"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/lyCabecera"
        android:paddingLeft="4dp"
        android:paddingRight="4dp"
        android:layout_width="match_parent"
        android:layout_height="36dp"
        android:paddingHorizontal="4dp"/>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerviewItemsGV"
        android:background="@drawable/background"
        android:layout_width="match_parent"
        android:layout_height="350dp"/>
</LinearLayout>
