<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardCornerRadius="8dp"
    app:cardElevation="4dp">

    <!-- ScrollView que envuelve todo el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">


            <!-- **************************layout 1**********************************  -->
            <LinearLayout
                android:id="@+id/constraint"
                android:layout_width="match_parent"
                android:layout_height="35dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">

                <!-- LinearLayout para lblDias y txtDias -->
                <LinearLayout
                    android:layout_width="56dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblNumero"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="0dp"
                        android:text="Número:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtNumero"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:gravity="center"
                        android:hint=""
                        android:inputType="number"
                        android:padding="8dp" />

                    <ImageButton
                        android:id="@+id/btnBuscarPv"
                        android:layout_width="50dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:src="@mipmap/ic_buscar_foreground"
                        android:contentDescription="buscar"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="10dp" />

                </LinearLayout>


                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblFecha"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="20dp"
                        android:text="Fecha:" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtFecha"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:hint=""

                        android:inputType="number"
                        android:padding="8dp" />
                </LinearLayout>
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblVendedor"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="20dp"
                        android:text="Vendedor:" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtVendedor"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:hint=""
                        android:inputType="text"
                        android:padding="8dp" />
                </LinearLayout>
            </LinearLayout>
            <!-- **************************layout 2**********************************  -->

            <LinearLayout
                android:id="@+id/layout2"
                android:layout_width="788dp"
                android:layout_height="40dp"
                android:layout_marginTop="12dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Prioridad:"
                    android:textColor="@color/black"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerPrioridad"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tipo Ped.:"
                    android:textColor="@color/black"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerTipoPed"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Forma Pag:"
                    android:textColor="@color/black"
                    android:textSize="20dp"
                    android:textStyle="bold" />

                <Spinner
                    android:id="@+id/spinnerFormaPag"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

            </LinearLayout>

            <!-- **************************layout 3**********************************  -->
            <LinearLayout
                android:id="@+id/layout3"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="10dp"
                android:textSize="20dp"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Plazo:"
                    android:textSize="20dp"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

                <Spinner
                    android:id="@+id/spinnerPlazo"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Seguro:"
                    android:textSize="20dp"
                    android:textColor="@color/black"
                    android:textStyle="bold"/>

                <Spinner
                    android:id="@+id/spinnerSeguro"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1" />



            </LinearLayout>
            <!-- **************************layout 4**********************************  -->
            <LinearLayout
                android:id="@+id/layout4"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="131dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblCliente"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Cliente:"
                        android:textColor="@color/black"
                        android:textSize="20dp"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <AutoCompleteTextView
                        android:id="@+id/txtCliente"
                        android:layout_width="300dp"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese el cliente"
                        android:inputType="textPersonName|textNoSuggestions"
                        android:completionThreshold="3" />

                </LinearLayout>
                <LinearLayout
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">
                    <TextView
                        android:id="@+id/lblPolitica"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Politica:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtPolitica"
                        android:layout_width="200dp"
                        android:layout_marginLeft="5dp"
                        android:layout_height="wrap_content"
                        android:inputType="text" />

                </LinearLayout>


            </LinearLayout>
            <!-- **************************layout5**********************************  -->
            <LinearLayout
                android:id="@+id/layout5"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblTrasnporte"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Transporte:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <AutoCompleteTextView
                        android:id="@+id/txtTransporte"
                        android:layout_width="200dp"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese el transporte"
                        android:inputType="textPersonName|textNoSuggestions"
                        android:completionThreshold="3"/>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblOrden"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Numero Orden:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtOrden"
                        android:layout_width="230dp"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese el numero de orden"
                        android:inputType="number" />
                </LinearLayout>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/layout6"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="2dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal">

                    <!-- lblDias -->
                    <TextView
                        android:id="@+id/lblObservacion"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Observación:"
                        android:textSize="20dp"
                        android:padding="5dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtObservacion"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese la observacion"
                        android:inputType="text" />

                </LinearLayout>

            </LinearLayout>
        </LinearLayout>
    </ScrollView>
</androidx.cardview.widget.CardView>