<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/constraintPrincipal"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            tools:ignore="MissingConstraints"
            tools:layout_editor_absoluteX="-42dp">

            <TextView
                android:id="@+id/textView4"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"
                android:text="Criterios"
                android:textColor="@color/black"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">

            </TextView>

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint"
                style="@style/BorderedLayout"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:layout_constraintTop_toBottomOf="@+id/textView4"
                tools:ignore="MissingConstraints"
                tools:layout_editor_absoluteX="-42dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:id="@+id/layoutPrincipal"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:id="@+id/layout"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:orientation="vertical"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintEnd_toStartOf="@id/layout2"
                        android:layout_marginRight="10dp">

                        <!-- Bloque para número de pedido -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight=".3"
                                android:layout_marginRight="13dp"
                                android:layout_gravity="center"
                                android:text="Item:"
                                android:textSize="@dimen/font_size_medium"
                                android:textColor="@color/black"
                                android:textStyle="bold" />


                            <AutoCompleteTextView
                                android:id="@+id/txtItemIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1.7"
                                android:textSize="@dimen/font_size_medium"
                                android:layout_marginLeft="10dp"
                                android:gravity="center"
                                android:inputType="textPersonName|textNoSuggestions"
                                android:completionThreshold="4"/>




                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight=".3"
                                android:layout_marginRight="13dp"
                                android:layout_gravity="center"
                                android:text="Marca: "
                                android:textSize="@dimen/font_size_medium"
                                android:textColor="@color/black"
                                android:textStyle="bold" />


                            <AutoCompleteTextView
                                android:id="@+id/txtMarcaIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1.7"
                                android:layout_marginLeft="10dp"
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:text=""
                                android:inputType="textPersonName|textNoSuggestions"
                                android:completionThreshold="2"/>


                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:weightSum="2">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="47dp"
                                android:layout_gravity="center"
                                android:layout_marginRight="13dp"
                                android:layout_weight=".3"
                                android:text="Cliente:"
                                android:textColor="@color/black"
                                android:textSize="@dimen/font_size_medium"
                                android:textStyle="bold" />


                            <AutoCompleteTextView
                                android:id="@+id/txtClienteIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1.7"
                                android:layout_marginLeft="10dp"
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:text=""
                                android:inputType="textPersonName|textNoSuggestions"
                                android:completionThreshold="3"/>


                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:orientation="horizontal"
                            android:weightSum="5">

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight=".9"
                                android:layout_gravity="center"
                                android:textSize="@dimen/font_size_medium"
                                android:textColor="@color/black"
                                android:text="Fecha Inicial"
                                android:textStyle="bold"
                                android:gravity="center_vertical" />

                            <EditText
                                android:id="@+id/txtFechaInicialIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:gravity="center"
                                android:layout_weight="1.1"
                                android:focusable="false"
                                android:hint="fecha" />

                            <TextView
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight=".8"
                                android:text="Fecha Final"
                                android:textSize="@dimen/font_size_medium"
                                android:textColor="@color/black"
                                android:textStyle="bold"
                                android:gravity="center_vertical"/>

                            <EditText
                                android:id="@+id/txtFechaFinalIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1.2"
                                android:focusable="false"
                                android:gravity="center"
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:hint="fecha" />


                            <Button
                                android:id="@+id/btnBusquedaIC"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="1"
                                android:textSize="@dimen/font_size_PreciosStock"
                                android:layout_marginLeft="10dp"
                                android:text="Buscar">
                            </Button>

                        </LinearLayout>

                    </LinearLayout>

                </LinearLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:id="@+id/lblBusqueda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Detalles"
                android:textColor="@color/black"
                android:textSize="20dp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHorizontal_bias="0.0"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/constraint" />


            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/constraint2"
                style="@style/BorderedLayout"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/lblBusqueda"
                app:layout_constraintBottom_toBottomOf="parent"
                tools:ignore="MissingConstraints">


                <LinearLayout
                    android:id="@+id/layout3"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:weightSum="7">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.3"
                        android:text="# Sri"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight=".9"
                        android:text="Bodega"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.2"
                        android:text="Fecha Factura"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1.1"
                        android:text="Tipo Factura"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight=".9"
                        android:text="Cantidad"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="1"
                        android:text="Precio Venta"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight=".6"
                        android:text="Total"
                        android:gravity="center"
                        android:textSize="@dimen/font_size_PreciosStock"
                        android:textColor="@color/black"
                        android:textStyle="bold" />


                </LinearLayout>


                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewIC"
                    android:layout_width="match_parent"
                    android:layout_height="700dp"
                    android:layout_marginTop="4dp"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/layout3" />


            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
</androidx.constraintlayout.widget.ConstraintLayout>