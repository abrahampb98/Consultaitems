<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/cardRoot"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardElevation="4dp"
    app:cardCornerRadius="8dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground"
    android:descendantFocusability="blocksDescendants">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintCombo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/background"
        android:padding="12dp"
        android:clickable="false"
        android:focusable="false">

        <!-- Fila 1: código + nombre -->
        <LinearLayout
            android:id="@+id/llFila1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="2"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight=".5"
                android:text="Combo:"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_cardView" />

            <TextView
                android:id="@+id/tvComboCab"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1.5"
                android:text="CB001 - Nombre del combo"
                android:textSize="@dimen/font_size_cardView" />
        </LinearLayout>

        <!-- Fila 2: fuente -->
        <LinearLayout
            android:id="@+id/llFila2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/llFila1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Fuente:"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:id="@+id/tvFuente"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Pedido"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="Compra Histórica:"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:id="@+id/tvHistQty"
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="wrap_content"
                android:text="0"
                android:textSize="@dimen/font_size_cardView"/>


        </LinearLayout>

        <!-- Fila 3: cobertura / histórico -->
        <LinearLayout
            android:id="@+id/llFila3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:weightSum="4"
            android:layout_marginTop="4dp"
            app:layout_constraintTop_toBottomOf="@+id/llFila2"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:layout_width="0dp"
                android:layout_weight="1.4"
                android:layout_height="wrap_content"
                android:text="Cobertura:"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:id="@+id/tvCobertura"
                android:layout_width="0dp"
                android:layout_weight="0.6"
                android:layout_height="wrap_content"
                android:text="0/0"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Lote Final:"
                android:textStyle="bold"
                android:textSize="@dimen/font_size_cardView"/>

            <TextView
                android:id="@+id/tvLote"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="0.00"
                android:textSize="@dimen/font_size_cardView"/>


        </LinearLayout>

        <!-- Lista de ítems del combo -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvComboItems"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:nestedScrollingEnabled="false"
            android:clickable="false"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_marginTop="8dp"
            app:layout_constraintTop_toBottomOf="@+id/llFila3"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
