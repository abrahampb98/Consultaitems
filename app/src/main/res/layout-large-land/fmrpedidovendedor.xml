<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">
    <!-- ScrollView que envuelve todo el contenido -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:focusable="true"
            android:focusableInTouchMode="true">


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Criterios"
                android:textSize="20dp"
                android:textColor="@color/black"
                android:textStyle="bold" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            style="@style/BorderedLayout">


                <!-- **************************layout 1**********************************  -->
                <LinearLayout
                    android:id="@+id/constraint"
                    android:layout_width="match_parent"
                    android:layout_height="35dp"
                    android:orientation="horizontal">

                    <!-- LinearLayout para lblDias y txtDias -->
                    <LinearLayout
                        android:layout_width="56dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblNumero"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="0dp"
                            android:text="Número:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtNumero"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"
                            android:gravity="center"
                            android:hint=""
                            android:inputType="number"
                            android:padding="8dp" />

                        <ImageButton
                            android:id="@+id/btnBuscarPv"
                            android:layout_width="50dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:src="@mipmap/ic_buscar1_foreground"
                        android:contentDescription="buscar"
                        android:background="?android:attr/selectableItemBackground"
                        android:padding="10dp" />
                    </LinearLayout>


                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblFecha"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="20dp"
                            android:text="Fecha:" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtFecha"
                            android:layout_width="130dp"
                            android:layout_height="match_parent"
                            android:hint=""
                            android:focusable="false"
                            android:focusableInTouchMode="false"
                            android:clickable="true"
                            android:inputType="none"
                            android:padding="8dp" />
                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblVendedor"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textColor="@color/black"
                            android:textStyle="bold"
                            android:textSize="20dp"
                            android:text="Vendedor:" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtVendedor"
                            android:layout_width="130dp"
                            android:layout_height="wrap_content"
                            android:hint=""
                            android:inputType="text"
                            android:padding="8dp" />
                    </LinearLayout>
                </LinearLayout>

                <!-- **************************layout 2**********************************  -->

                <LinearLayout
                    android:id="@+id/layout2"
                    android:layout_width="745dp"
                    android:layout_height="40dp"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Prioridad:"
                        android:textColor="@color/black"
                        android:textSize="20dp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerPrioridad"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tipo Ped.:"
                        android:textColor="@color/black"
                        android:textSize="20dp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerTipoPed"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".4" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Forma Pag:"
                        android:textColor="@color/black"
                        android:textSize="20dp"
                        android:textStyle="bold" />

                    <Spinner
                        android:id="@+id/spinnerFormaPag"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".6" />

                </LinearLayout>

                <!-- **************************layout 3**********************************  -->
                <LinearLayout
                    android:id="@+id/layout3"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:textSize="20dp"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Plazo:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spinnerPlazo"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Seguro:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold"/>

                    <Spinner
                        android:id="@+id/spinnerSeguro"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1" />



                </LinearLayout>
                <!-- **************************layout 4**********************************  -->
                <LinearLayout
                    android:id="@+id/layout4"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="131dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblCliente"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cliente:"
                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <AutoCompleteTextView
                            android:id="@+id/txtCliente"
                            android:layout_width="370dp"
                            android:layout_height="wrap_content"
                            android:hint="Ingrese el cliente"
                            android:inputType="textPersonName|textNoSuggestions"
                            android:completionThreshold="3" />

                    </LinearLayout>
                    <LinearLayout
                        android:layout_width="70dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".7"
                        android:orientation="horizontal">
                        <TextView
                            android:id="@+id/lblPolitica"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Politica:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtPolitica"
                            android:layout_width="200dp"
                            android:layout_marginLeft="5dp"
                            android:layout_height="wrap_content"
                            android:inputType="text" />

                    </LinearLayout>


                </LinearLayout>
                <!-- **************************layout5**********************************  -->
                <LinearLayout
                    android:id="@+id/layout5"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblTrasnporte"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Transporte:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <AutoCompleteTextView
                            android:id="@+id/txtTransporte"
                            android:layout_width="330dp"
                            android:layout_height="wrap_content"
                            android:hint="Ingrese el transporte"
                            android:inputType="textPersonName|textNoSuggestions"
                            android:completionThreshold="3"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblOrden"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="# Orden:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtOrden"
                            android:layout_width="200dp"
                            android:layout_height="wrap_content"
                            android:hint="Ingrese la orden"
                            android:inputType="number" />
                    </LinearLayout>
                </LinearLayout>
                <LinearLayout
                    android:id="@+id/layout6"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- lblDias -->
                        <TextView
                            android:id="@+id/lblObservacion"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Observación:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtObservacion"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:hint="Ingrese la observacion"
                            android:inputType="text" />

                    </LinearLayout>

                </LinearLayout>

        </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Busqueda"
                android:textSize="20dp"
                android:textColor="@color/black"
                android:textStyle="bold" />


        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="5dp"
            style="@style/BorderedLayout">

        <!-- **************************layout7**********************************  -->
                <LinearLayout
                    android:id="@+id/layout7"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout6"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="88dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtReferencia"
                            android:layout_width="250dp"
                            android:layout_height="wrap_content"
                            android:hint="Referencia.."
                            android:inputType="text"
                            android:padding="8dp"
                            android:textSize="20dp" />

                        <Button
                            android:id="@+id/btnOK"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:background="@android:color/background_light"
                            android:drawableStart="@mipmap/ic_buscar2"/>


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="131dp"
                        android:layout_height="40dp"
                        android:layout_weight="1"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Tipo Desct.:"

                            android:textColor="@color/black"
                            android:textSize="20dp"
                            android:textStyle="bold" />

                        <Spinner
                            android:id="@+id/spinnerItem"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />


                    </LinearLayout>


                </LinearLayout>


                <!-- **************************layout6**********************************  -->
                <LinearLayout
                    android:id="@+id/layout8"
                    android:layout_width="match_parent"
                    android:layout_height="40dp"
                    android:layout_below="@+id/layout7"
                    android:layout_marginTop="2dp"
                    android:orientation="horizontal">

                    <LinearLayout
                        android:layout_width="110dp"
                        android:layout_height="wrap_content"
                        android:layout_weight=".4"
                        android:orientation="horizontal">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Desct.:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtDescuento"
                            android:layout_width="100dp"
                            android:text="0.00"
                            android:layout_height="wrap_content"
                            android:hint="Ingrese el descuento"
                            android:inputType="numberDecimal"
                            android:padding="8dp" />


                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="141dp"
                        android:layout_height="match_parent"
                        android:layout_weight=".3"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/lblCantidad"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:padding="5dp"
                            android:text="Cantidad:"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <!-- txtDias -->
                        <EditText
                            android:id="@+id/txtCantidad"
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:hint="cantidad"
                            android:inputType="number"
                            android:padding="8dp" />

                    </LinearLayout>

                <LinearLayout
                    android:layout_width="131dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:orientation="horizontal">


                    <TextView
                        android:id="@+id/lblPrec"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:padding="5dp"
                        android:text="Precio:"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />

                    <!-- txtDias -->
                    <EditText
                        android:id="@+id/txtPre"
                        android:layout_width="160dp"
                        android:layout_height="wrap_content"
                        android:hint="Ingrese el precio"
                        android:inputType="numberDecimal"
                        android:padding="8dp" />

                    <Button
                        android:id="@+id/btnAgregar"
                        android:layout_width="wrap_content"
                        android:layout_height="45dp"
                        android:layout_marginLeft="10dp"
                        android:gravity="center"
                        android:background="@android:color/background_light"
                        android:drawableStart="@mipmap/ic_agregar_foreground" />





                </LinearLayout>
                </LinearLayout>



                <!-- **************************layout13**********************************  -->
                <LinearLayout
                    android:id="@+id/layout9"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout8"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">


                    <TextView
                        android:id="@+id/lblReferencia"
                        android:layout_width="108dp"
                        android:layout_height="wrap_content"
                        android:text="Referencia"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="18dp"/>

                    <TextView
                        android:id="@+id/lblDescrip"
                        android:layout_width="280dp"
                        android:layout_height="match_parent"
                        android:text="Descripcion"
                        android:textColor="@color/black"
                        android:textSize="18dp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/lblStock"
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Stock"
                        android:textColor="@color/black"
                        android:textSize="18dp"
                        android:textStyle="bold" />


                    <TextView
                        android:id="@+id/lblPreSub"
                        android:layout_width="75dp"
                        android:layout_height="wrap_content"
                        android:text="P. Sub"
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="18dp"/>


                    <TextView
                        android:id="@+id/lblPreCont"
                        android:layout_width="75dp"
                        android:layout_height="wrap_content"
                        android:text="P. Cont."
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="18dp"/>


                    <TextView
                        android:id="@+id/lblPreCred"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="P. Cred."
                        android:textColor="@color/black"
                        android:textStyle="bold"
                        android:textSize="18dp"/>

                </LinearLayout>



                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/recyclerViewRef"
                    android:layout_width="match_parent"
                    android:layout_height="150dp"
                    android:layout_below="@id/layout9"
                    android:layout_marginTop="4dp" />
        </LinearLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Detalle"
                android:textSize="20dp"
                android:textColor="@color/black"
                android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="5dp"
            style="@style/BorderedLayout">

                <!-- **************************layout10**********************************  -->
                <LinearLayout
                    android:id="@+id/layout10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/recyclerViewRef"
                    android:layout_marginTop="6dp"
                    android:orientation="horizontal">


                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                                               android:text="Codigo"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="160dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="9dp"
                            android:text="Referencia"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="100dp"
                            android:layout_height="wrap_content"
                            android:text="%Descto"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Cant."
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                        <TextView
                            android:layout_width="70dp"
                            android:layout_height="wrap_content"
                            android:text="Precio"
                            android:layout_marginLeft="20dp"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />


                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="20dp"
                            android:text="Subtotal"
                            android:textSize="20dp"
                            android:textColor="@color/black"
                            android:textStyle="bold" />

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="20dp"
                        android:text="ConDescto"
                        android:textSize="20dp"
                        android:textColor="@color/black"
                        android:textStyle="bold" />



                </LinearLayout>


                <LinearLayout
                    android:id="@+id/layout11"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout10"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal">


                        <!-- **************************recyclerView detalle**********************************  -->
                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/recyclerViewDetalle"
                        android:layout_width="match_parent"
                        android:layout_height="150dp"
                        android:layout_marginTop="0dp" />

                </LinearLayout>

        </LinearLayout>


            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Totales"
                android:textSize="20dp"
                android:textColor="@color/black"
                android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="5dp"
            style="@style/BorderedLayout">

                <!-- **************************layout7**********************************  -->
                <LinearLayout
                    android:id="@+id/layout12"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@+id/layout11"
                    android:layout_marginTop="4dp"
                    android:orientation="horizontal">
                            <TextView
                                android:layout_width="90dp"
                                android:layout_height="wrap_content"
                                android:text="Lote"
                                android:textColor="@color/black"
                                android:textSize="24dp"
                                android:textStyle="bold" />

                            <TextView
                                android:id="@+id/lblSub"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Subtotal:"
                                android:padding="2dp"
                                android:textColor="@color/black"
                                android:textSize="24dp"
                                android:textStyle="bold" />

                        <TextView
                            android:id="@+id/txtSubotal"
                            android:layout_width="120dp"
                            android:layout_height="wrap_content"
                            android:layout_marginLeft="5dp"
                            android:layout_marginRight="10dp"
                            android:gravity="right"
                            android:textSize="24dp"
                            android:text="0.00"
                            android:textColor="@color/black" />





                        <TextView
                            android:id="@+id/lblDesc"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="(+)Seguro:"
                            android:textColor="@color/black"
                            android:textSize="24dp"
