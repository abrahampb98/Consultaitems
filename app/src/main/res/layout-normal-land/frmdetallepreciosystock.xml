<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/rootLayout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/frmseleccionitem"
    android:orientation="vertical">


    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraint"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:id="@+id/layoutItem"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal"
            android:weightSum="15">

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="2.6"
            android:id="@+id/txtRefPS"
            android:text="Referencia "
            android:textSize="12dp"
            android:textColor="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight=".5"
            android:id="@+id/txtSkuPS"
            android:gravity="center"
            android:text="Sku "
            android:textSize="12dp"
            android:textColor="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight=".9"
            android:gravity="center"
            android:id="@+id/txtTotalPS"
            android:text="Total "
            android:textSize="12dp"
            android:layout_gravity="center"
            android:textColor="@color/black" />


        <FrameLayout
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight=".4"
            android:layout_marginLeft="10dp">

            <!-- ImageView con el borde -->
            <ImageView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:src="@drawable/border" />

            <!-- Agregar otra imagen en el centro -->
            <ImageView
                android:id="@+id/stockImageViewPS"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_gravity="center"
                android:src="@mipmap/ic_buscar2_foreground" />
        </FrameLayout>


            <TextView
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight="1.25"
                android:id="@+id/txtMarcaPS"
                android:text="Marca "
                android:gravity="right"
                android:textSize="12dp"
                android:textColor="@color/black" />



        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1.3"
            android:id="@+id/txtContadoPS"
            android:text="Contado "
            android:gravity="right"
            android:textSize="12dp"

            android:textColor="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:id="@+id/txtCreditoPS"
            android:text="Credito "
            android:textSize="12dp"
            android:gravity="right"
            android:textColor="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:id="@+id/txtPublicoPS"
            android:text="Publico "
            android:textSize="12dp"
            android:gravity="right"
            android:textColor="@color/black" />


        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1.2"
            android:id="@+id/txtFinalPS"
            android:text="Publ.+Iva"
            android:textSize="12dp"
            android:gravity="right"
            android:textColor="@color/black" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1.1"
            android:paddingLeft="10dp"
            android:id="@+id/txtPesoPS"
            android:text="Peso(Kg.) "
            android:textSize="12dp"
            android:gravity="right"
            android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".9"
                android:paddingLeft="15dp"
                android:id="@+id/txtLsubPS"
                android:text="0.00"
                android:textSize="12dp"
                android:gravity="right"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".8"
                android:paddingLeft="10dp"
                android:id="@+id/txtLcontPS"
                android:text="0.00"
                android:textSize="12dp"
                android:gravity="right"
                android:textColor="@color/black" />


            <TextView
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".9"
                android:paddingLeft="10dp"
                android:id="@+id/txtLcredPS"
                android:text="0.00"
                android:textSize="12dp"
                android:gravity="right"
                android:textColor="@color/black" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".8"
                android:paddingLeft="10dp"
                android:id="@+id/txtLpubPS"
                android:text="0.00"
                android:textSize="12dp"
                android:gravity="right"
                android:textColor="@color/black" />


            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="30dp"
                android:layout_weight=".4"
                android:layout_marginLeft="10dp">

                <!-- ImageView con el borde -->
                <ImageView
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:src="@drawable/border" />

                <!-- Agregar otra imagen en el centro -->
                <ImageView
                    android:id="@+id/WebImageViewPS"
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_gallery" />
            </FrameLayout>

            </LinearLayout>

            <LinearLayout
                app:layout_constraintTop_toBottomOf="@+id/layoutItem"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                android:layout_width="wrap_content"
                android:layout_height="match_parent">
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#CCCCCC"/>
            </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>

